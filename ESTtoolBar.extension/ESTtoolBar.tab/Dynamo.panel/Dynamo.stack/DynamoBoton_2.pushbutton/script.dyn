    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "NodeType": "PythonScriptNode",
      "Code": "all_schedules=IN[0]  # Se obtienen todas las vistas disponibles\r\nused_schedules=IN[1] # Se obtienen las vistas que ya están en uso\r\n\r\nunused_schedules=[]  # Se crea una lista vacía para almacenar las vistas no utilizadas\r\n\r\n# Se recorre cada vista en la lista de todas las vistas\r\nfor schedule in all_schedules:\r\n    # Si la vista no está en la lista de vistas utilizadas\r\n    if not(schedule in used_schedules):\r\n        # Se agrega esa vista a la lista de vistas no utilizadas\r\n        unused_schedules.append(schedule)\r\n        \r\n# La salida del script será la lista de vistas no utilizadas        \r\nOUT=unused_schedules",
      "Engine": "CPython3",
      "VariableInputPorts": true,
      "Id": "2ee903727b044da49d917a912fd3f763",
      "Inputs": [
        {
          "Id": "40d557748e694044b48f873c4feab725",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "8ee1e775c21f4c05901483c511735546",
          "Name": "IN[1]",
          "Description": "Input #1",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
        {
          "Id": "acc4cf302306465abaab7ea663009d50",
          "Name": "OUT",
          "Description": "Result of the python script",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "Runs an embedded Python script."
    },
