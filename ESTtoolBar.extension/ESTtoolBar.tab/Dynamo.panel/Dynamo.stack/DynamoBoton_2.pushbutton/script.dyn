    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "NodeType": "PythonScriptNode",
      "Code": "all_views=IN[0]  # Se obtienen todas las vistas disponibles\r\nused_views=IN[1] # Se obtienen las vistas que ya están en uso\r\n\r\nunused_views=[]  # Se crea una lista vacía para almacenar las vistas no utilizadas\r\n\r\n# Se recorre cada vista en la lista de todas las vistas\r\nfor view in all_views:\r\n    # Si la vista no está en la lista de vistas utilizadas\r\n    if not(view in used_views):\r\n        # Se agrega esa vista a la lista de vistas no utilizadas\r\n        unused_views.append(view)\r\n        \r\n# La salida del script será la lista de vistas no utilizadas        \r\nOUT=unused_views",
      "Engine": "CPython3",
      "VariableInputPorts": true,
      "Id": "ab728c8561264f1b8e32c01fce3551f6",
      "Inputs": [
        {
          "Id": "7dca27ea1d63416a87d4a4835aedb7a0",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "d1c94541feb04c3aaf6df1db8d5d419a",
          "Name": "IN[1]",
          "Description": "Input #1",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
        {
          "Id": "bf95a15cfaf841efa1e6f68cb5039951",
          "Name": "OUT",
          "Description": "Result of the python script",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "Runs an embedded Python script."
    },
