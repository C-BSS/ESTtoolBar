    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "NodeType": "PythonScriptNode",
      "Code": "import clr\r\nclr.AddReference('RevitAPI')\r\nfrom Autodesk.Revit.DB import *\r\n\r\nclr.AddReference('RevitServices')\r\nimport RevitServices\r\nfrom RevitServices.Persistence import DocumentManager\r\nfrom RevitServices.Transactions import TransactionManager\r\n\r\n# Obtiene el documento actual de Revit\r\n# doc = DocumentManager.Instance.CurrentDBDocument\r\ndoc = IN[0]\r\n\r\n# Obtiene la lista de nombres de parámetros de entrada\r\nparam_names = IN[1]\r\n\r\n# Obtiene la lista de parámetros de la familia actual\r\nparam_list = doc.FamilyManager.GetParameters()\r\nnames = [p.Definition.Name for p in param_list]\r\n\r\n# Inicializa una lista para almacenar los resultados\r\nresults = []\r\n\r\n# Verifica si cada nombre de parámetro en la lista existe en la lista de nombres\r\nfor param_name in param_names:\r\n    par1 = None\r\n    if param_name in names:\r\n        par1 = param_list[names.index(param_name)]\r\n    \r\n    # Si el parámetro existe, intenta eliminar la fórmula asociada\r\n    if par1 is not None:\r\n        TransactionManager.Instance.EnsureInTransaction(doc)\r\n        try:\r\n            # Elimina la fórmula del parámetro\r\n            doc.FamilyManager.SetFormula(par1, None)\r\n            results.append(f'Success: {param_name}')\r\n        except Exception as e:\r\n            results.append(f'Failed: {param_name} - {str(e)}')\r\n        TransactionManager.Instance.TransactionTaskDone()\r\n    else:\r\n        results.append(f'Failed: {param_name} - Parameter not found')\r\n\r\n# Salida de los resultados\r\nOUT = results",
      "Engine": "CPython3",
      "VariableInputPorts": true,
      "Id": "53bdd5d832c540c288e3cc94f0179163",
      "Inputs": [
        {
          "Id": "8d5f18d376804d04b0d2831393d2fd60",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "904436e37ceb4cd4ad452a8aba3a3a07",
          "Name": "IN[1]",
          "Description": "Input #1",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
        {
          "Id": "19e0950005e1454cab22c8fdddfab0a9",
          "Name": "OUT",
          "Description": "Result of the python script",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "Runs an embedded Python script."
    },
